# .env.example
# Notion Integration Token (ntn_...)
NOTION_API_KEY=your_notion_api_key_here

# OpenAI API Key for Interactive Agent and/or Batch Processor
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Gemini API Key if you want to use Gemini instead of OpenAI
GEMINI_API_KEY=your_gemini_api_key_here

# Notion Database ID for Batch Processor (UUID format, 32 characters)
NOTION_DATABASE_ID=your_database_id_here

# Notion default Page ID for Interactive Agent (optional)
NOTION_PAGE_ID=your_default_page_id_here
